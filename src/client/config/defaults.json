{
	"application": {
		"name": "Hong Kong Mosquito Watch",
		"title": "HK Mosquito Watch",
		"year": "2026",
		"organization": {
			"name": "Hong Kong Mosquito Watch",
			"url": "#main"
		}
	},

	"footer": {
		"logo": "images/logos/icon.svg"
	},

	"map": {
		"center": [22.3193, 114.1694],
		"zoom": 11,
		"mode": "map",
		"boundary": "data/boundaries/hksar_18_district_boundary.json",
		"bounds": {
			"lat": {
				"min": 22.15,
				"max": 22.58
			},
			"lon": {
				"min": 113.825,
				"max": 114.45
			}
		},
		"markerSize": {
			"desktop": 6,
			"mobile": 20
		}
	},

	"sources": [
		"inaturalist",
		"digitomy",
		"fehd_gravidtrap",
		"fehd_gravidtrap_area"
	],

	"leaflet": {
		"inertia": true,
		"inertiaDeceleration": 500,
		"minZoom": 9,
		"maxZoom": 18,
		"maxBounds": [[22.05, 113.7], [22.7, 114.6]],
		"maxBoundsViscosity": 0.8,
		"zoomControl": false
	},

	"navbar": {
		"icon": "images/logos/icon.svg",
		"title": "HK Mosquito Watch",
		"align": "center",

		"navs": {
			"about": {
				"text": "About / 關於",
				"icon": "fa fa-info-circle",
				"href": "#about"
			},
			"data": {
				"text": "Explore / 探索",
				"icon": "fa fa-table",
				"href": "#main",
				"color": "#3060e0"
			},
			"code": {
				"text": "Source",
				"icon": "fab fa-github",
				"href": "https://github.com/HanzhiChen02/MosquitoHK"
			}
		}
	},

	"clustering": {
		"disableClusteringAtZoom": 7,
		"spiderfyOnMaxZoom": false,
		"showCoverageOnHover": false,
		"animate": true
	},

	"timeline": {
		"source": "inaturalist",
		"interval": "month"
	}
}
